{
  "name": "protobuf-fastdsl",
  "version": "0.1.5",
  "type": "module",
  "main": "dist/runtime.js",
  "types": "protobuf.d.ts",
  "files": [
    "dist",
    "protobuf.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./protobuf.d.ts",
      "import": "./dist/runtime.js"
    },
    "./vite": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/runtime.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npx tsx bench/index.ts"
  },
  "dependencies": {
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}